# =====================================================
#  BOUTIDIDACT — Backend-for-Frontend (BFF)
#  Copier ce fichier en .env et renseigner les valeurs.
# =====================================================

# ---- Serveur ----
PORT=3001
# Origines CORS autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ---- Hiboutik ----
# Sous-domaine de votre compte : https://<HIBOUTIK_ACCOUNT>.hiboutik.com
HIBOUTIK_ACCOUNT=monboutik
# E-mail de connexion Hiboutik
HIBOUTIK_USER=admin@exemple.com
# Clé API (Réglages > API dans Hiboutik)
HIBOUTIK_API_KEY=remplacer_par_la_cle_api
# IDs par défaut (récupérables via /api/hiboutik/bootstrap)
HIBOUTIK_STORE_ID=1
HIBOUTIK_VENDOR_ID=1
# Identifiant client par défaut (0 = walk-in / passage)
HIBOUTIK_DEFAULT_CUSTOMER_ID=0
# Codes "payment_means" Hiboutik (à adapter au compte)
HIBOUTIK_PAYMENT_CARD=CB
HIBOUTIK_PAYMENT_CASH=ESP

# ---- Imprimante ESC/POS ----
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100
# EPSON ou STAR
PRINTER_TYPE=EPSON
# Largeur en caractères (42 pour 80mm, 32 pour 58mm)
PRINTER_WIDTH=42
# Ouverture du tiroir-caisse après impression (true/false)
PRINTER_OPEN_DRAWER=false

# ---- Mentions ticket (NF525-light) ----
SHOP_NAME=BOUTIDIDACT
SHOP_ADDRESS=12 Rue de l'Exemple, 75000 Paris
SHOP_SIRET=000 000 000 00000
SHOP_TVA=FR00000000000
SHOP_FOOTER=Merci de votre visite !

# ---- Mode dégradé ----
# Si true : si Hiboutik est injoignable, on autorise une vente "offline" imprimée seule
ALLOW_OFFLINE_FALLBACK=false

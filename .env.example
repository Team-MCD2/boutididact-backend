# =====================================================
#  BOUTIDIDACT — Backend-for-Frontend (BFF)
#  Copier ce fichier en .env et renseigner les valeurs.
# =====================================================

# ---- Serveur ----
PORT=3001
# Origines CORS autorisées (séparées par des virgules)
# IMPORTANT : pour une tablette, ajouter l'IP LAN du PC : http://192.168.1.XX:4173
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ---- Configuration API (SaaS Dynamique) ----
# Note: Ces valeurs sont désormais configurables via l'admin de la borne.
HIBOUTIK_ACCOUNT=
HIBOUTIK_USER=
HIBOUTIK_API_KEY=
HIBOUTIK_STORE_ID=1
HIBOUTIK_VENDOR_ID=1
HIBOUTIK_DEFAULT_CUSTOMER_ID=0
HIBOUTIK_PAYMENT_CARD=CB
HIBOUTIK_PAYMENT_CASH=ESP

# ---- Imprimante (UI) ----
PRINTER_IP=
PRINTER_PORT=9100
PRINTER_TYPE=EPSON
PRINTER_WIDTH=42
PRINTER_OPEN_DRAWER=false

# ---- Mentions ticket (UI) ----
SHOP_NAME=
SHOP_ADDRESS=
SHOP_SIRET=
SHOP_TVA=
SHOP_FOOTER=Merci de votre visite !

# ---- Mode dégradé ----
# Si true : autorise l'impression même si Hiboutik est hors-ligne
ALLOW_OFFLINE_FALLBACK=false

# ---- SaaS & IA (Premium) ----
# Stripe : Pour activer l'abonnement
STRIPE_SECRET_KEY=sk_test_...
# Gemini : Pour l'extraction de menu par photo
GEMINI_API_KEY=
# ---- SMTP (Notifications Admin) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Plusieurs adresses séparées par des virgules pour recevoir les notifications
ADMIN_EMAIL_RECEIVER=admin1@mail.com,admin2@mail.com

# ---- Sécurité Admin (Route /admin-setup) ----
ADMIN_PASSWORD=0000

